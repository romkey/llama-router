# llama-router configuration
# Copy to .env and edit as needed. All variables are optional — defaults shown.

# General
TZ=America/New_York

# Database
LLAMA_ROUTER_DATABASE_PATH=llama_router.db

# Dashboard
LLAMA_ROUTER_DASHBOARD_HOST=0.0.0.0
LLAMA_ROUTER_DASHBOARD_PORT=80

# Ollama API
LLAMA_ROUTER_API_HOST=0.0.0.0
LLAMA_ROUTER_API_PORT=11434

# llama.cpp / OpenAI-compatible API
LLAMA_ROUTER_LLAMACPP_HOST=0.0.0.0
LLAMA_ROUTER_LLAMACPP_PORT=8080

# Health checks
LLAMA_ROUTER_HEALTH_CHECK_INTERVAL_SECONDS=30

# Benchmarking
LLAMA_ROUTER_BENCHMARK_PROMPT=Write a short sentence about the weather.

# OCI Registry Pull-Through Cache
LLAMA_ROUTER_CACHE_ENABLED=true
LLAMA_ROUTER_CACHE_DIR=./model_cache
LLAMA_ROUTER_CACHE_HOST=0.0.0.0
LLAMA_ROUTER_CACHE_PORT=9200
# Required for cache to work with remote Ollama backends — set to the
# IP or hostname that your Ollama backends can use to reach this machine
LLAMA_ROUTER_CACHE_EXTERNAL_HOST=
LLAMA_ROUTER_CACHE_MANIFEST_TTL_HOURS=240
